# 复制为 .env 并按需修改：cp .env.example .env

# --- 模型与权重缓存 ---
# SAM 模型 id（HF hub id 或容器内本地权重路径）
SAM_MODEL_ID=facebook/sam-vit-base
# 宿主机权重缓存目录，bind mount 到容器 /app/.cache/huggingface。
# 指向 JuiceFS 挂载点即可把大文件放到外部存储，例如 /mnt/juicefs/sam-infer/hf-cache
HF_CACHE_DIR=./hf-cache

# --- 服务 ---
SERVER_PORT=8422
LOG_LEVEL=INFO
DEVICE=

# --- 鉴权 ---
PROVIDER_API_KEY=changeme
AUTH_HEADER=X-API-Key
TOKEN_HEADER=X-Session-Token
TOKEN_TTL_SECONDS=3600

# --- 其他 ---
PUBLIC_URL=
CORS_ORIGIN=
